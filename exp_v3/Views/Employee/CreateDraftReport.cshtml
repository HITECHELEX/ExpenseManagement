@model ExpenseManagement.ViewModels.CreateReportVM
@using ExpenseManagement.Models
@{
    ViewData["Title"] = "Create New Report";
    decimal walletBalance = ViewBag.WalletBalance ?? 0m;
    int primaryBudgetId = ViewBag.PrimaryBudgetId ?? 0;
    bool isOver = walletBalance < 0;
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/Employee/Dashboard" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    <h5 class="mb-0">Create New Expense Report</h5>
</div>

@* Wallet Balance Card *@
<div class="card mb-3 border-0" style="background:@(isOver?"linear-gradient(135deg,#dc2626,#991b1b)":"linear-gradient(135deg,#2563eb,#1d4ed8)");border-radius:16px;color:#fff">
    <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span style="opacity:.8;font-size:.85rem">
                <i class="fas fa-wallet me-2"></i>
                @(isOver ? "⚠️ Wallet Over Budget" : "Your Wallet Balance")
            </span>
            <span style="opacity:.7;font-size:.78rem">Report will use this balance</span>
        </div>
        <div style="font-size:2.4rem;font-weight:800;letter-spacing:-1px">
            @(isOver?"-":"")₹@Math.Abs(walletBalance).ToString("N2")
        </div>
        @if (isOver)
        {
            <div style="margin-top:8px;background:rgba(0,0,0,.2);border-radius:10px;padding:8px 12px;font-size:.82rem">
                <i class="fas fa-info-circle me-1"></i>
                Wallet is negative. You can still create a report — expenses will deepen the deficit which will be recovered from your next allocation.
            </div>
        }
        else
        {
            <div style="opacity:.7;font-size:.82rem;margin-top:4px">
                Spend up to ₹@walletBalance.ToString("N2") — or exceed for overspend recovery
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-file-plus me-2"></i>Report Details</div>
    <div class="card-body">
        <form method="post" action="/Employee/CreateDraftReport">
            @Html.AntiForgeryToken()
            @* Hidden: BudgetId is automatically set to the primary budget *@
            <input type="hidden" name="BudgetId" value="@primaryBudgetId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-3" style="border-radius:10px">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    { <div>@e.ErrorMessage</div> }
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold">Report Title <span class="text-danger">*</span></label>
                <input type="text" name="ReportTitle" class="form-control" required
                       placeholder="e.g. Sales Trip Mumbai – Jan 2025, Field Visit Pune" />
                <small class="text-muted">Give a descriptive name for this batch of expenses.</small>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Summary / Purpose</label>
                <textarea name="Summary" class="form-control" rows="3"
                          placeholder="Brief description of the business purpose or trip..."></textarea>
            </div>

            <div class="alert alert-info" style="border-radius:12px;font-size:.87rem">
                <i class="fas fa-info-circle me-2"></i>
                <strong>How it works:</strong> A draft report is created against your wallet balance of
                <strong>@(isOver?"-":"")₹@Math.Abs(walletBalance).ToString("N2")</strong>.
                Add daily expenses one-by-one with date and bill photo. When done, forward to Account Team.
                <br><small class="text-muted mt-1 d-block">
                    <i class="fas fa-exclamation-triangle me-1 text-warning"></i>
                    You can exceed your wallet balance — overspend is auto-recovered from your next budget allocation.
                </small>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3" style="border-radius:12px;font-weight:700;font-size:.95rem">
                <i class="fas fa-file-plus me-2"></i>Create Draft Report
            </button>
        </form>
    </div>
</div>
