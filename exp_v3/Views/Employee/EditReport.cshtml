@model ExpenseManagement.ViewModels.EditReportVM
@{ ViewData["Title"] = "Edit Report"; }

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/Employee/ReportDetail/@Model.ReportId" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
    <h5 class="mb-0">Edit Report Details</h5>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-edit me-2"></i>Update Report Info</div>
    <div class="card-body">
        <form method="post" action="/Employee/EditReport">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ReportId" value="@Model.ReportId" />

            <div asp-validation-summary="All" class="alert alert-danger mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Report Title <span class="text-danger">*</span></label>
                <input type="text" name="ReportTitle" class="form-control" value="@Model.ReportTitle" required
                       placeholder="e.g. Sales Trip Mumbai - Jan 2025" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Summary / Notes</label>
                <textarea name="Summary" class="form-control" rows="4"
                          placeholder="Brief description of expenses in this report...">@Model.Summary</textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Changes
                </button>
                <a href="/Employee/ReportDetail/@Model.ReportId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
