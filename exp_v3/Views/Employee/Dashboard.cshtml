@model ExpenseManagement.ViewModels.EmployeeDashboardVM
@using ExpenseManagement.Models
@{
    ViewData["Title"] = "Dashboard";
    ViewBag.UnreadNotifications = Model.UnreadNotifications;
    var usableBudgets = Model.Budgets.Where(b => !b.IsLocked).ToList();
    bool canCreateReport = usableBudgets.Any();
    bool isOverspentTotal = Model.TotalBalance < 0;
}

@* ── STAT CARDS ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff;color:#2563eb"><i class="fas fa-wallet"></i></div>
            <div class="stat-value">₹@Model.TotalAllocated.ToString("N0")</div>
            <div class="stat-label">Total Allocated</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7;color:#d97706"><i class="fas fa-shopping-cart"></i></div>
            <div class="stat-value">₹@Model.TotalSpent.ToString("N0")</div>
            <div class="stat-label">Total Spent</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card @(isOverspentTotal ? "border-danger" : "")">
            <div class="stat-icon" style="background:@(isOverspentTotal ? "#fee2e2" : "#d1fae5");color:@(isOverspentTotal ? "#dc2626" : "#16a34a")">
                <i class="fas fa-coins"></i>
            </div>
            @if (isOverspentTotal)
            {
                <div class="stat-value text-danger">-₹@Math.Abs(Model.TotalBalance).ToString("N0")</div>
                <div class="stat-label text-danger">Over Budget</div>
                <small class="text-danger" style="font-size:.72rem">Recovered from next allocation</small>
            }
            else
            {
                <div class="stat-value budget-remaining">₹@Model.TotalBalance.ToString("N0")</div>
                <div class="stat-label">Available Balance</div>
            }
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#ede9fe;color:#7c3aed"><i class="fas fa-file-alt"></i></div>
            <div class="stat-value">@Model.DraftReports.Count</div>
            <div class="stat-label">Draft Reports</div>
        </div>
    </div>
</div>

@* ── DRAFT REPORTS ── *@
@if (Model.DraftReports.Any())
{
    <div class="card mb-4 border-info">
        <div class="card-header d-flex justify-content-between align-items-center" style="background:#eff6ff">
            <span><i class="fas fa-edit me-2 text-primary"></i>Draft Reports — Continue Adding Expenses</span>
            @if (canCreateReport)
            {
                <a href="/Employee/CreateDraftReport" class="btn btn-sm btn-outline-primary">+ New Report</a>
            }
        </div>
        <div class="card-body p-0">
            @foreach (var r in Model.DraftReports)
            {
                var budget = Model.Budgets.FirstOrDefault(b => b.Id == r.BudgetId);
                var livebal = budget?.RemainingBalance ?? 0;
                var isOv = livebal < 0;
                <div class="d-flex align-items-center justify-content-between p-3 border-bottom @(isOv ? "bg-warning-subtle" : "")">
                    <div>
                        <div class="fw-semibold">@r.ReportTitle</div>
                        <small class="text-muted">@r.ExpenseClaims.Count expense(s) · ₹@r.TotalClaimed.ToString("N2") claimed</small>
                        @if (budget != null)
                        {
                            <div class="mt-1">
                                @if (isOv)
                                {
                                    <small class="text-danger fw-semibold">
                                        <i class="fas fa-exclamation-triangle me-1"></i>
                                        Over by ₹@Math.Abs(livebal).ToString("N2") — recovered from next allocation
                                    </small>
                                }
                                else
                                {
                                    <small class="text-success fw-semibold">
                                        <i class="fas fa-coins me-1"></i>Balance: ₹@livebal.ToString("N2")
                                    </small>
                                }
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 flex-shrink-0">
                        <a href="/Employee/AddExpense?reportId=@r.Id" class="btn btn-sm btn-primary">
                            <i class="fas fa-plus me-1"></i>Add
                        </a>
                        <a href="/Employee/EditReport/@r.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a href="/Employee/ReportDetail/@r.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-eye"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="row g-3">
    @* ── MY BUDGETS ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-wallet me-2"></i>My Budgets</span>
                <a href="/Employee/MyBudgets" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Budgets.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>No budgets allocated yet
                    </div>
                }
                @foreach (var b in Model.Budgets.Where(b => !b.IsLocked).Take(3))
                {
                    var pct = b.TotalAmount > 0 ? (double)(b.SpentAmount / b.TotalAmount * 100) : 0;
                    var isNeg = b.RemainingBalance < 0;
                    <div class="p-3 border-bottom @(isNeg ? "bg-danger-subtle" : "")">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold text-truncate me-2">@b.Purpose</span>
                            @if (isNeg)
                            {
                                <span class="text-danger fw-bold flex-shrink-0">-₹@Math.Abs(b.RemainingBalance).ToString("N0")</span>
                            }
                            else
                            {
                                <span class="text-success fw-bold flex-shrink-0">₹@b.RemainingBalance.ToString("N0")</span>
                            }
                        </div>
                        <div class="progress mb-1">
                            <div class="progress-bar @(isNeg ? "bg-danger" : pct > 80 ? "bg-danger" : pct > 60 ? "bg-warning" : "bg-success")"
                                 style="width:@(Math.Min(100,pct))%"></div>
                        </div>
                        <small class="text-muted">₹@b.SpentAmount.ToString("N0") of ₹@b.TotalAmount.ToString("N0") used</small>
                        @if (isNeg)
                        {
                            <div class="mt-1"><small class="text-danger"><i class="fas fa-info-circle me-1"></i>Over-budget amount recovered from next allocation</small></div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── RECENT CLAIMS ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-receipt me-2"></i>Recent Claims</span>
                <a href="/Employee/MyClaims" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentClaims.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>No claims yet
                    </div>
                }
                @foreach (var c in Model.RecentClaims.Take(6))
                {
                    <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
                        <div class="text-truncate me-2">
                            <div class="fw-semibold text-truncate">@c.Title</div>
                            <small class="text-muted">@c.Category · @c.SubmittedOn.ToString("dd MMM")</small>
                        </div>
                        <div class="text-end flex-shrink-0">
                            <div class="fw-bold">₹@c.Amount.ToString("N0")</div>
                            <span class="badge @(c.Status == ExpenseStatus.Approved ? "badge-approved" : c.Status == ExpenseStatus.Declined ? "badge-declined" : "badge-pending") rounded-pill">
                                @c.Status
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    @if (canCreateReport)
    {
        <a href="/Employee/CreateDraftReport" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Report
        </a>
    }
    else
    {
        <button class="btn btn-secondary" disabled
                title="No active budget — ask Account Team to allocate">
            <i class="fas fa-lock me-2"></i>Create New Report
        </button>
    }
    <a href="/Employee/MyReports" class="btn btn-outline-secondary">
        <i class="fas fa-file-invoice me-2"></i>All Reports
    </a>
    <a href="/Employee/MyBudgets" class="btn btn-outline-secondary">
        <i class="fas fa-wallet me-2"></i>My Budgets
    </a>
</div>
