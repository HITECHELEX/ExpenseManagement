@using ExpenseManagement.Models
@{
    ViewData["Title"] = "Settle Report Balance";
    var report   = ViewBag.Report as ExpenseReport;
    var budgets  = ViewBag.Budgets as List<Budget> ?? new List<Budget>();
    decimal balance = report?.RemainingBalanceAtSubmission ?? 0;
    bool isOverspent = balance < 0;
    string defaultPurpose = $"Returned – {report?.ReportTitle}";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/AccountTeam/ReportDetail/@report?.Id" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
    <h5 class="mb-0">@(isOverspent ? "Record Overspend" : "Transfer Returned Balance")</h5>
</div>

@if (isOverspent)
{
    <!-- OVERSPEND CASE: just confirm crystallising the debt -->
    <div class="card mb-4 border-0" style="background:linear-gradient(135deg,#dc2626,#991b1b);border-radius:16px;color:#fff">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div style="width:52px;height:52px;background:rgba(255,255,255,.2);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div>
                    <div style="opacity:.8;font-size:.82rem;letter-spacing:.3px">OVERSPEND FROM</div>
                    <div class="fw-semibold fs-6">@report?.ReportTitle</div>
                </div>
            </div>
            <div style="font-size:2.8rem;font-weight:800;letter-spacing:-1.5px;margin:8px 0">₹@Math.Abs(balance).ToString("N2")</div>
            <div style="opacity:.75;font-size:.82rem">
                <i class="fas fa-user me-1"></i>@report?.Employee?.FullName
                &nbsp;·&nbsp;
                <i class="fas fa-check-circle me-1"></i>Approved by Management
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h6 class="fw-semibold mb-3"><i class="fas fa-info-circle text-warning me-2"></i>What happens when you confirm:</h6>
            <ul class="mb-0" style="font-size:.9rem">
                <li class="mb-2">The overspend of <strong>₹@Math.Abs(balance).ToString("N2")</strong> is recorded against <strong>@report?.Employee?.FullName</strong></li>
                <li class="mb-2">It will be <strong>automatically deducted</strong> from their next budget allocation</li>
                <li class="mb-2">The source budget will be <strong>locked</strong> (no new reports can be created against it)</li>
                <li>The employee will be <strong>notified</strong></li>
            </ul>
        </div>
    </div>

    <form method="post" action="/AccountTeam/TransferBalance">
        @Html.AntiForgeryToken()
        <input type="hidden" name="reportId" value="@report?.Id" />
        <input type="hidden" name="transferMode" value="overspend" />
        <button type="submit" class="btn btn-danger w-100 py-3"
               style="font-size:1rem;font-weight:700;border-radius:12px">
            <i class="fas fa-check-circle me-2"></i>Confirm — Record Overspend of ₹@Math.Abs(balance).ToString("N2")
        </button>
    </form>
    <p class="text-muted text-center mt-2" style="font-size:.78rem">
        <i class="fas fa-lock me-1"></i>Source budget will be locked and employee notified.
    </p>
}
else
{
    <!-- POSITIVE BALANCE CASE: transfer back to employee budget -->
    <div class="card mb-4 border-0" style="background:linear-gradient(135deg,#16a34a,#15803d);border-radius:16px;color:#fff">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div style="width:52px;height:52px;background:rgba(255,255,255,.2);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">
                    <i class="fas fa-coins"></i>
                </div>
                <div>
                    <div style="opacity:.8;font-size:.82rem;letter-spacing:.3px">RETURNED BALANCE FROM</div>
                    <div class="fw-semibold fs-6">@report?.ReportTitle</div>
                </div>
            </div>
            <div style="font-size:2.8rem;font-weight:800;letter-spacing:-1.5px;margin:8px 0">₹@balance.ToString("N2")</div>
            <div style="opacity:.75;font-size:.82rem">
                <i class="fas fa-user me-1"></i>@report?.Employee?.FullName
                &nbsp;·&nbsp;
                <i class="fas fa-check-circle me-1"></i>Approved by Management
                &nbsp;·&nbsp;
                <i class="fas fa-calendar me-1"></i>@report?.ManagementReviewedOn?.ToString("dd MMM yyyy")
            </div>
        </div>
    </div>

    <form method="post" action="/AccountTeam/TransferBalance">
        @Html.AntiForgeryToken()
        <input type="hidden" name="reportId" value="@report?.Id" />

        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="fas fa-route me-2"></i>Where should this balance go?
            </div>
            <div class="card-body p-3">

                <!-- Option A: Create new budget (recommended) -->
                <div id="optNew" onclick="selectMode('new')"
                     style="border:2px solid #2563eb;border-radius:14px;padding:18px;cursor:pointer;background:#eff6ff;margin-bottom:12px;transition:all .2s">
                    <div class="d-flex align-items-start gap-3">
                        <input type="radio" name="transferMode" value="new" id="radioNew" checked onchange="selectMode('new')" class="mt-1" />
                        <div class="flex-grow-1">
                            <label for="radioNew" class="fw-semibold d-block mb-1" style="cursor:pointer;font-size:1rem">
                                <i class="fas fa-plus-circle text-primary me-2"></i>Create New Budget
                                <span class="badge bg-primary ms-2" style="font-size:.7rem">Recommended</span>
                            </label>
                            <small class="text-muted">A fresh budget of ₹@balance.ToString("N2") created for @report?.Employee?.FullName with a clear label.</small>
                            <div id="newBudgetFields" class="mt-3">
                                <div class="mb-3">
                                    <label class="form-label">Budget Label <span class="text-danger">*</span></label>
                                    <input type="text" name="newBudgetPurpose" class="form-control"
                                           id="newPurposeInput" value="@defaultPurpose"
                                           placeholder="e.g. Returned Balance – Sales Trip" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Valid Until (optional)</label>
                                    <input type="date" name="newBudgetValidUntil" class="form-control" />
                                </div>
                                <div class="p-3 rounded mt-3" style="background:#f0fdf4;border:1px solid #bbf7d0">
                                    <div class="fw-semibold mb-1" style="font-size:.85rem;color:#065f46"><i class="fas fa-eye me-1"></i>Preview</div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold" id="previewName">@defaultPurpose</div>
                                            <small class="text-muted">New · Active · Allocated today</small>
                                        </div>
                                        <div class="text-success fw-bold">₹@balance.ToString("N2")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Option B: Add to existing budget -->
                <div id="optExisting" onclick="selectMode('existing')"
                     style="border:2px solid #e2e8f0;border-radius:14px;padding:18px;cursor:pointer;background:#fff;transition:all .2s">
                    <div class="d-flex align-items-start gap-3">
                        <input type="radio" name="transferMode" value="existing" id="radioExisting"
                               @(!budgets.Any() ? "disabled" : "") onchange="selectMode('existing')" class="mt-1" />
                        <div class="flex-grow-1">
                            <label for="radioExisting" class="fw-semibold d-block mb-1" style="cursor:pointer;font-size:1rem">
                                <i class="fas fa-layer-group text-success me-2"></i>Add to Existing Budget
                            </label>
                            <small class="text-muted">Top up an existing active budget with ₹@balance.ToString("N2").</small>
                            @if (budgets.Any())
                            {
                                <div id="existingBudgetSelect" class="mt-3 d-none">
                                    <label class="form-label">Select Budget</label>
                                    <select name="existingBudgetId" class="form-select" id="budgetDropdown" onchange="updatePreview()">
                                        <option value="">-- Choose a budget --</option>
                                        @foreach (var b in budgets)
                                        {
                                            <option value="@b.Id" data-current="@b.RemainingBalance" data-purpose="@b.Purpose">
                                                @b.Purpose — Balance: ₹@b.RemainingBalance.ToString("N2")
                                            </option>
                                        }
                                    </select>
                                    <div id="existingPreview" class="mt-2 p-3 rounded d-none" style="background:#f0fdf4;border:1px solid #bbf7d0">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-muted" style="font-size:.83rem">Current balance</span>
                                            <span id="prevCurrent" class="fw-semibold"></span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-muted" style="font-size:.83rem">+ Transfer</span>
                                            <span class="fw-semibold text-success">+ ₹@balance.ToString("N2")</span>
                                        </div>
                                        <hr class="my-2" />
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-semibold">New balance</span>
                                            <span id="prevNew" class="fw-bold text-success fs-6"></span>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-secondary mt-2 mb-0 py-2 px-3" style="font-size:.8rem">
                                    <i class="fas fa-info-circle me-1"></i>No active unlocked budgets. Use "Create New Budget" instead.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-success w-100 py-3"
                style="font-size:1rem;font-weight:700;border-radius:12px">
            <i class="fas fa-paper-plane me-2"></i>Transfer ₹@balance.ToString("N2") to Employee
        </button>
        <p class="text-muted text-center mt-2" style="font-size:.78rem">
            <i class="fas fa-lock me-1"></i>After transfer, the source budget will be locked and the employee notified.
        </p>
    </form>
}

@section Scripts {
<script>
const xferBalance = @balance;

function selectMode(mode) {
    const rE = document.getElementById('radioExisting');
    const rN = document.getElementById('radioNew');
    const oE = document.getElementById('optExisting');
    const oN = document.getElementById('optNew');
    const eS = document.getElementById('existingBudgetSelect');
    const nF = document.getElementById('newBudgetFields');
    if (mode === 'new') {
        rN.checked = true;
        oN.style.borderColor = '#2563eb'; oN.style.background = '#eff6ff';
        oE.style.borderColor = '#e2e8f0'; oE.style.background = '#fff';
        if (nF) nF.style.display = '';
        if (eS) eS.classList.add('d-none');
    } else {
        rE.checked = true;
        oE.style.borderColor = '#16a34a'; oE.style.background = '#f0fdf4';
        oN.style.borderColor = '#e2e8f0'; oN.style.background = '#fff';
        if (nF) nF.style.display = 'none';
        if (eS) eS.classList.remove('d-none');
    }
}
function updatePreview() {
    const sel = document.getElementById('budgetDropdown');
    const opt = sel?.options[sel.selectedIndex];
    const preview = document.getElementById('existingPreview');
    if (opt?.value) {
        const cur = parseFloat(opt.dataset.current) || 0;
        document.getElementById('prevCurrent').textContent = '₹' + cur.toLocaleString('en-IN', {minimumFractionDigits:2});
        document.getElementById('prevNew').textContent = '₹' + (cur + xferBalance).toLocaleString('en-IN', {minimumFractionDigits:2});
        preview.classList.remove('d-none');
    } else { preview.classList.add('d-none'); }
}
document.getElementById('newPurposeInput')?.addEventListener('input', function() {
    document.getElementById('previewName').textContent = this.value || '@defaultPurpose';
});
</script>
}
