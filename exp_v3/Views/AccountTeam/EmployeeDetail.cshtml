@model ExpenseManagement.Models.User
@using ExpenseManagement.Models
@{
    ViewData["Title"] = $"{Model.FullName} — Details";
    var budgets = Model.Budgets.OrderByDescending(b => b.AllocatedOn).ToList();
    var activeBudgets = budgets.Where(b => b.IsActive && !b.IsLocked).ToList();
    var walletBal = activeBudgets.Sum(b => b.RemainingBalance);
    var reports = ViewBag.Reports as List<ExpenseReport> ?? new();
    var colors = new[]{"#2563eb","#7c3aed","#db2777","#16a34a","#d97706"};
    var avatarColor = colors[Math.Abs(Model.FullName.GetHashCode()) % colors.Length];
    var initials = string.Join("", Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0]));
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a href="/AccountTeam/Employees" class="btn btn-outline-secondary btn-sm" style="border-radius:8px">
        <i class="fas fa-arrow-left me-1"></i>Back to Employees
    </a>
</div>

@* ── PROFILE HERO ── *@
<div class="card mb-4 border-0" style="background:linear-gradient(135deg,#1e3a8a,#2563eb);border-radius:20px;color:#fff">
    <div class="card-body p-4">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <div style="width:72px;height:72px;border-radius:18px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;color:#fff;flex-shrink:0">
                @initials
            </div>
            <div class="flex-fill">
                <h3 class="mb-1 fw-bold">@Model.FullName</h3>
                <div style="opacity:.8">@Model.Email · @(Model.Department ?? "No Department")</div>
                <div style="opacity:.6;font-size:.8rem">Member since @Model.CreatedAt.ToString("MMMM yyyy")</div>
            </div>
            <div class="d-flex gap-2">
                <a href="/AccountTeam/EditEmployee/@Model.Id" class="btn btn-light btn-sm fw-semibold">
                    <i class="fas fa-edit me-1"></i>Edit
                </a>
                <a href="/AccountTeam/AllocateBudget" class="btn btn-warning btn-sm fw-semibold">
                    <i class="fas fa-wallet me-1"></i>Allocate
                </a>
            </div>
        </div>
    </div>
</div>

@* ── WALLET SUMMARY ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Wallet Balance</div>
            <div class="stat-value @(walletBal<0?"text-danger":"text-success")">
                @(walletBal<0?"-":"")₹@Math.Abs(walletBal).ToString("N0")
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Total Allocated</div>
            <div class="stat-value">₹@activeBudgets.Sum(b=>b.TotalAmount).ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Total Spent</div>
            <div class="stat-value text-warning">₹@activeBudgets.Sum(b=>b.SpentAmount).ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Reports</div>
            <div class="stat-value">@reports.Count</div>
        </div>
    </div>
</div>

<div class="row g-4">
    @* ── BUDGET HISTORY ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="fas fa-wallet me-2"></i>Budget History</div>
            <div class="card-body p-0">
                @if (!budgets.Any())
                {
                    <div class="text-center py-4 text-muted">No budgets yet</div>
                }
                @foreach (var b in budgets)
                {
                    var pct = b.TotalAmount > 0 ? Math.Min(100,(double)(b.SpentAmount/b.TotalAmount*100)) : 0;
                    <div class="p-3 border-bottom @(b.IsLocked?"opacity-50":"")">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div class="fw-semibold" style="font-size:.9rem">@b.Purpose</div>
                                <small class="text-muted">@b.AllocatedOn.ToString("dd MMM yyyy")</small>
                            </div>
                            @if (b.IsLocked)
                            { <span class="badge bg-secondary"><i class="fas fa-lock me-1"></i>Locked</span> }
                            else if (b.IsActive)
                            { <span class="badge badge-approved">Active</span> }
                        </div>
                        <div class="d-flex justify-content-between" style="font-size:.82rem">
                            <span class="text-muted">₹@b.SpentAmount.ToString("N0") / ₹@b.TotalAmount.ToString("N0")</span>
                            <span class="@(b.RemainingBalance<0?"text-danger":"text-success") fw-semibold">
                                @(b.RemainingBalance<0?"-":"")₹@Math.Abs(b.RemainingBalance).ToString("N0")
                            </span>
                        </div>
                        <div class="progress mt-1" style="height:4px">
                            <div class="progress-bar @(pct>80?"bg-danger":pct>60?"bg-warning":"bg-success")" style="width:@pct%"></div>
                        </div>
                        @if (b.OverspentAmount > 0)
                        { <small class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>₹@b.OverspentAmount.ToString("N0") debt pending</small> }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── REPORT HISTORY ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="fas fa-file-invoice me-2"></i>Report History</div>
            <div class="card-body p-0">
                @if (!reports.Any())
                { <div class="text-center py-4 text-muted">No reports</div> }
                @foreach (var r in reports.Take(8))
                {
                    var (cls,txt) = r.Status switch {
                        ReportStatus.Draft => ("badge-draft","Draft"),
                        ReportStatus.SubmittedToAccountTeam => ("badge-submitted","Submitted"),
                        ReportStatus.ForwardedToManagement => ("badge-forwarded","At Mgmt"),
                        ReportStatus.ApprovedByManagement => ("badge-approved","Approved"),
                        ReportStatus.RejectedByManagement => ("badge-rejected","Rejected"),
                        _ => ("badge-secondary",r.Status.ToString())
                    };
                    <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
                        <div>
                            <div class="fw-semibold" style="font-size:.88rem">@r.ReportTitle</div>
                            <small class="text-muted">@r.CreatedOn.ToString("dd MMM yyyy") · ₹@r.TotalClaimed.ToString("N0")</small>
                        </div>
                        <span class="badge @cls">@txt</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
