@model List<ExpenseManagement.Models.ExpenseClaim>
@{ ViewData["Title"] = "Review Claims"; }
@using ExpenseManagement.Models

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-bold">Review Expense Claims</h5>
        <p class="text-muted mb-0" style="font-size:.85rem;">Approve or decline employee expense claims</p>
    </div>
</div>

<div class="mb-3">
    <a asp-action="Claims" asp-route-status="" class="btn btn-sm @(ViewBag.CurrentStatus=="Pending"?"btn-warning text-dark":"btn-outline-secondary") me-1">Pending</a>
    <a asp-action="Claims" asp-route-status="Approved" class="btn btn-sm @(ViewBag.CurrentStatus=="Approved"?"btn-success":"btn-outline-secondary") me-1">Approved</a>
    <a asp-action="Claims" asp-route-status="Declined" class="btn btn-sm @(ViewBag.CurrentStatus=="Declined"?"btn-danger":"btn-outline-secondary")">Declined</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-receipt fa-3x mb-3 d-block" style="opacity:.3;"></i>No claims to review.
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead><tr>
                    <th>#</th><th>Employee</th><th>Title</th><th>Category</th><th>Amount</th><th>Budget</th><th>Submitted</th><th>Receipt</th>
                    @if (ViewBag.CurrentStatus == "Pending") { <th>Action</th> } else { <th>Status</th> }
                </tr></thead>
                <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="text-muted" style="font-size:.78rem;">#@c.Id</td>
                        <td style="font-size:.82rem;">
                            <div class="fw-semibold">@c.Employee?.FullName</div>
                            <div class="text-muted" style="font-size:.75rem;">@c.Employee?.Department</div>
                        </td>
                        <td style="font-size:.82rem;">
                            <div class="fw-semibold">@c.Title</div>
                            @if (!string.IsNullOrEmpty(c.Description))
                            {
                                <div class="text-muted" style="font-size:.75rem;">@(c.Description.Length > 40 ? c.Description[..40] + "…" : c.Description)</div>
                            }
                        </td>
                        <td><span class="badge bg-light text-dark border" style="font-size:.72rem;">@c.Category</span></td>
                        <td class="fw-bold" style="color:#1e293b;">₹@c.Amount.ToString("N2")</td>
                        <td class="text-muted" style="font-size:.78rem;">@c.Budget?.Purpose</td>
                        <td class="text-muted" style="font-size:.78rem;">@c.SubmittedOn.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.ReceiptPath))
                            {
                                <a href="@c.ReceiptPath" target="_blank" class="btn btn-xs btn-outline-secondary" style="font-size:.72rem; padding:2px 8px;">
                                    <i class="fas fa-file me-1"></i>View
                                </a>
                            }
                            else { <span class="text-muted" style="font-size:.75rem;">None</span> }
                        </td>
                        @if (ViewBag.CurrentStatus == "Pending")
                        {
                            <td>
                                <button class="btn btn-sm btn-success me-1" style="font-size:.75rem;" onclick="reviewClaim(@c.Id, true)">
                                    <i class="fas fa-check me-1"></i>Approve
                                </button>
                                <button class="btn btn-sm btn-danger" style="font-size:.75rem;" onclick="reviewClaim(@c.Id, false)">
                                    <i class="fas fa-times me-1"></i>Decline
                                </button>
                            </td>
                        }
                        else
                        {
                            var bCls = c.Status == ExpenseStatus.Approved ? "badge-approved" : "badge-declined";
                            <td>
                                <span class="badge @bCls" style="font-size:.72rem;">@c.Status</span>
                                @if (!string.IsNullOrEmpty(c.AccountTeamRemarks))
                                {
                                    <div class="text-muted mt-1" style="font-size:.72rem;">@c.AccountTeamRemarks</div>
                                }
                            </td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Review Claim</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="reviewForm" asp-controller="AccountTeam" asp-action="ReviewClaim" method="post">
                    <input type="hidden" name="ClaimId" id="claimId" />
                    <input type="hidden" name="IsApproved" id="isApproved" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary" style="font-size:.83rem;">Remarks <small class="text-muted">(optional)</small></label>
                        <textarea name="Remarks" class="form-control" rows="3" placeholder="Add any comments for the employee..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="submitBtn">Confirm</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function reviewClaim(id, isApproved) {
    document.getElementById('claimId').value = id;
    document.getElementById('isApproved').value = isApproved;
    document.getElementById('modalTitle').textContent = isApproved ? '✅ Approve Claim' : '❌ Decline Claim';
    document.getElementById('submitBtn').className = isApproved ? 'btn btn-success' : 'btn btn-danger';
    document.getElementById('submitBtn').textContent = isApproved ? 'Approve' : 'Decline';
    new bootstrap.Modal(document.getElementById('reviewModal')).show();
}
</script>
}
