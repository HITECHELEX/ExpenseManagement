@model ExpenseManagement.Models.ExpenseReport
@using ExpenseManagement.Models
@{ ViewData["Title"] = Model.ReportTitle; }

@{
    var (badgeCls, badgeTxt) = Model.Status switch {
        ReportStatus.Draft                   => ("badge-draft","Draft"),
        ReportStatus.SubmittedToAccountTeam  => ("badge-submitted","Submitted to Accounts"),
        ReportStatus.ReviewedByAccountTeam   => ("badge-reviewed","Reviewed by Accounts"),
        ReportStatus.ForwardedToManagement   => ("badge-forwarded","At Management"),
        ReportStatus.ApprovedByManagement    => ("badge-approved","Approved ✓"),
        ReportStatus.RejectedByManagement    => ("badge-rejected","Rejected by Management"),
        ReportStatus.RejectedByAccountTeam   => ("badge-rejected","Rejected – Action Required"),
        _ => ("badge-secondary","Unknown")
    };
    bool isDraft       = Model.Status == ReportStatus.Draft;
    bool isRejectedAT  = Model.Status == ReportStatus.RejectedByAccountTeam;
    bool canEdit       = isDraft || isRejectedAT;
    bool isViewOnly    = !canEdit;
    decimal walletBal  = (ViewBag.WalletBalance as decimal?) ?? Model.Budget?.RemainingBalance ?? 0;
}

@* ── HEADER ── *@
<div class="d-flex align-items-center mb-3 gap-2 flex-wrap">
    <a href="/Employee/MyReports" class="btn btn-outline-secondary btn-sm" style="border-radius:8px">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
    <h5 class="mb-0 me-auto fw-bold">@Model.ReportTitle</h5>
    <span class="badge @badgeCls px-3 py-2" style="font-size:.82rem">@badgeTxt</span>
    @* Edit/Delete only for Draft or Rejected-by-AT *@
    @if (canEdit)
    {
        <a href="/Employee/EditReport/@Model.Id" class="btn btn-sm btn-outline-primary" style="border-radius:8px">
            <i class="fas fa-edit me-1"></i>Edit
        </a>
        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteReportModal" style="border-radius:8px">
            <i class="fas fa-trash me-1"></i>Delete
        </button>
    }
</div>

@* ── REJECTION ALERT (Account Team) ── *@
@if (isRejectedAT && !string.IsNullOrEmpty(Model.AccountTeamNotes))
{
    <div class="alert alert-danger mb-3 d-flex gap-3 align-items-start" style="border-radius:12px">
        <i class="fas fa-times-circle fa-lg mt-1 flex-shrink-0"></i>
        <div>
            <strong>Rejected by Account Team</strong>
            <div class="mt-1">@Model.AccountTeamNotes</div>
            <small class="text-muted">Reviewed on @Model.AccountTeamVerifiedOn?.ToString("dd MMM yyyy HH:mm") by @Model.AccountTeamVerifiedBy?.FullName</small>
        </div>
    </div>
}

@* ── FEEDBACK ALERTS (Management) ── *@
@if (!string.IsNullOrEmpty(Model.ManagementFeedback))
{
    <div class="alert @(Model.Status==ReportStatus.ApprovedByManagement?"alert-success":"alert-danger") mb-3" style="border-radius:12px">
        <strong><i class="fas fa-comment me-2"></i>Management Feedback:</strong> @Model.ManagementFeedback
    </div>
}

@* ── SUBMITTED NOTICE (view-only) ── *@
@if (isViewOnly)
{
    <div class="alert alert-info mb-3 d-flex align-items-center gap-2" style="border-radius:12px;font-size:.87rem">
        <i class="fas fa-lock-open text-primary flex-shrink-0"></i>
        <span>
            This report was <strong>forwarded on @Model.ForwardedToAccountTeamOn?.ToString("dd MMM yyyy")</strong> and is now
            <strong>view-only</strong>. No further changes can be made.
        </span>
    </div>
}

@* ── STAT CARDS ── *@
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Report Total</div>
            <div class="stat-value text-warning">₹@Model.TotalClaimed.ToString("N2")</div>
            <small class="text-muted">@Model.ExpenseClaims.Count expense(s)</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            @if (isDraft)
            {
                <div class="stat-label">Wallet Balance</div>
                @if (walletBal >= 0)
                {
                    <div class="stat-value text-success">₹@walletBal.ToString("N2")</div>
                }
                else
                {
                    <div class="stat-value text-danger">-₹@Math.Abs(walletBal).ToString("N2")</div>
                    <small class="text-danger" style="font-size:.72rem">⚠️ Over budget</small>
                }
            }
            else
            {
                <div class="stat-label">Balance at Submit</div>
                @if (Model.RemainingBalanceAtSubmission >= 0)
                {
                    <div class="stat-value text-success">₹@Model.RemainingBalanceAtSubmission.ToString("N2")</div>
                    <small class="text-muted">Returned</small>
                }
                else
                {
                    <div class="stat-value text-danger">-₹@Math.Abs(Model.RemainingBalanceAtSubmission).ToString("N2")</div>
                    <small class="text-danger" style="font-size:.72rem">Recovered from next alloc.</small>
                }
            }
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Created</div>
            <div style="font-size:1rem;font-weight:700">@Model.CreatedOn.ToString("dd MMM yyyy")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Expenses</div>
            <div class="stat-value">@Model.ExpenseClaims.Count</div>
        </div>
    </div>
</div>

@* ── DRAFT / REJECTED-BY-AT ACTION BAR ── *@
@if (canEdit)
{
    <div class="alert @(walletBal < 0 ? "alert-warning" : isRejectedAT ? "alert-danger" : "alert-info") d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3" style="border-radius:12px">
        <div>
            <i class="fas fa-info-circle me-2"></i>
            @if (isRejectedAT)
            {
                <span>Report was <strong>rejected</strong>. Fix the issues and resubmit to Account Team.</span>
            }
            else if (walletBal < 0)
            {
                <span>Budget exceeded by <strong>₹@Math.Abs(walletBal).ToString("N2")</strong> — recovered from next allocation when you forward.</span>
            }
            else
            {
                <span>Report is <strong>Draft</strong>. Add expenses and forward to Account Team when done.</span>
            }
        </div>
        <div class="d-flex gap-2">
            <a href="/Employee/AddExpense?reportId=@Model.Id" class="btn btn-primary btn-sm" style="border-radius:8px">
                <i class="fas fa-plus me-1"></i>Add Expense
            </a>
            @if (Model.ExpenseClaims.Any())
            {
                <button type="button" class="btn @(isRejectedAT ? "btn-warning" : "btn-success") btn-sm" data-bs-toggle="modal" data-bs-target="#forwardModal" style="border-radius:8px">
                    <i class="fas fa-paper-plane me-1"></i>@(isRejectedAT ? "Resubmit to Accounts" : "Forward to Accounts")
                </button>
            }
        </div>
    </div>
}

@* ── PROGRESS TIMELINE ── *@
<div class="card mb-3">
    <div class="card-header"><i class="fas fa-stream me-2"></i>Report Progress</div>
    <div class="card-body">
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot done"></div>
                <strong>Draft Created</strong>
                <div class="text-muted" style="font-size:.8rem">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot @(Model.Status >= ReportStatus.SubmittedToAccountTeam ? "done" : "")"></div>
                <strong>Forwarded to Account Team</strong>
                @if (Model.ForwardedToAccountTeamOn.HasValue)
                { <div class="text-muted" style="font-size:.8rem">@Model.ForwardedToAccountTeamOn.Value.ToString("dd MMM yyyy HH:mm")</div> }
                else { <div class="text-muted" style="font-size:.8rem">Pending</div> }
            </div>
            <div class="timeline-item">
                <div class="timeline-dot @(Model.Status >= ReportStatus.ForwardedToManagement ? "done" : "")"></div>
                <strong>Reviewed by Account Team</strong>
                @if (Model.AccountTeamVerifiedOn.HasValue)
                {
                    <div class="text-muted" style="font-size:.8rem">
                        @Model.AccountTeamVerifiedOn.Value.ToString("dd MMM yyyy HH:mm")
                        @if (!string.IsNullOrEmpty(Model.AccountTeamNotes)) { <span>· @Model.AccountTeamNotes</span> }
                    </div>
                }
                else { <div class="text-muted" style="font-size:.8rem">Pending</div> }
            </div>
            <div class="timeline-item">
                <div class="timeline-dot @(Model.Status == ReportStatus.ApprovedByManagement ? "done" : Model.Status == ReportStatus.RejectedByManagement ? "rejected" : "")"></div>
                <strong>Management Decision</strong>
                @if (Model.ManagementReviewedOn.HasValue)
                {
                    <div class="text-muted" style="font-size:.8rem">
                        @Model.ManagementReviewedOn.Value.ToString("dd MMM yyyy HH:mm")
                        @if (!string.IsNullOrEmpty(Model.ManagementNotes)) { <span>· @Model.ManagementNotes</span> }
                    </div>
                }
                else { <div class="text-muted" style="font-size:.8rem">Pending</div> }
            </div>
        </div>
    </div>
</div>

@* ── EXPENSE TABLE ── *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>Expenses — Total: <strong>₹@Model.TotalClaimed.ToString("N2")</strong></span>
        @if (canEdit)
        {
            <a href="/Employee/AddExpense?reportId=@Model.Id" class="btn btn-sm btn-primary" style="border-radius:8px">
                <i class="fas fa-plus me-1"></i>Add
            </a>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" style="font-size:.87rem">
            <thead style="background:#f8fafc">
                <tr>
                    <th>Date</th>
                    <th>Title / Category</th>
                    <th>Payment Mode</th>
                    <th>Amount</th>
                    <th>Bill</th>
                    @if (!isDraft) { <th>Status</th> }
                    @if (canEdit) { <th style="width:80px"></th> }
                </tr>
            </thead>
            <tbody>
                @if (!Model.ExpenseClaims.Any())
                {
                    <tr><td colspan="6" class="text-center py-4 text-muted">
                        No expenses yet.
                        @if (canEdit) { <a href="/Employee/AddExpense?reportId=@Model.Id">Add your first expense →</a> }
                    </td></tr>
                }
                @foreach (var c in Model.ExpenseClaims.OrderBy(x => x.ExpenseDate))
                {
                    <tr>
                        <td style="white-space:nowrap">@c.ExpenseDate.ToString("dd MMM yy")</td>
                        <td>
                            <div class="fw-semibold">@c.Title</div>
                            <small class="text-muted">@c.Category</small>
                            @if (!string.IsNullOrEmpty(c.Description))
                            { <small class="text-muted d-block">@c.Description</small> }
                        </td>
                        <td style="white-space:nowrap">
                            @if (c.PaymentMethod == PaymentMethod.UPI)
                            {
                                <span class="badge rounded-pill px-2 py-1"
                                      style="background:#eff6ff;color:#2563eb;font-size:.75rem;font-weight:600">
                                    <i class="fas fa-mobile-alt me-1"></i>UPI / Online
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill px-2 py-1"
                                      style="background:#f0fdf4;color:#16a34a;font-size:.75rem;font-weight:600">
                                    <i class="fas fa-money-bill-wave me-1"></i>Cash
                                </span>
                            }
                        </td>
                        <td class="fw-semibold">₹@c.Amount.ToString("N2")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.ReceiptPath))
                            {
                                var ext = System.IO.Path.GetExtension(c.ReceiptPath).ToLower();
                                if (ext == ".pdf")
                                { <a href="@c.ReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger" style="border-radius:6px"><i class="fas fa-file-pdf"></i></a> }
                                else
                                { <a href="@c.ReceiptPath" target="_blank"><img src="@c.ReceiptPath" style="height:36px;width:36px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0" /></a> }
                            }
                            else { <span class="text-muted" style="font-size:.8rem">None</span> }
                        </td>
                        @if (!isDraft)
                        {
                            <td>
                                @if (c.Status == ExpenseStatus.Approved)
                                {
                                    <span class="badge bg-success px-2 py-1" style="font-size:.78rem">
                                        <i class="fas fa-check me-1"></i>OK
                                    </span>
                                }
                                else if (c.Status == ExpenseStatus.Declined)
                                {
                                    <div>
                                        <span class="badge bg-danger px-2 py-1" style="font-size:.78rem">
                                            <i class="fas fa-times me-1"></i>Rejected
                                        </span>
                                        @if (!string.IsNullOrEmpty(c.AccountTeamRemarks))
                                        {
                                            <div class="text-danger mt-1" style="font-size:.75rem">@c.AccountTeamRemarks</div>
                                        }
                                    </div>
                                }
                            </td>
                        }
                        @if (canEdit)
                        {
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Employee/EditExpense/@c.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:6px;padding:3px 8px"><i class="fas fa-edit"></i></a>
                                    <form method="post" action="/Employee/DeleteExpense" onsubmit="return confirm('Remove this expense?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="claimId" value="@c.Id" />
                                        <button class="btn btn-sm btn-outline-danger" style="border-radius:6px;padding:3px 8px"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
            @if (Model.ExpenseClaims.Any())
            {
                <tfoot>
                    <tr style="background:#f8fafc;font-weight:700">
                        <td colspan="3" style="text-align:right">TOTAL</td>
                        <td>₹@Model.ExpenseClaims.Sum(c => c.Amount).ToString("N2")</td>
                        <td colspan="@(1 + (!isDraft ? 1 : 0) + (canEdit ? 1 : 0))"></td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@* ── FORWARD MODAL (draft or rejected-by-AT only) ── *@
@if (canEdit && Model.ExpenseClaims.Any())
{
    <div class="modal fade" id="forwardModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px;border:none">
                <div class="modal-header" style="border-bottom:1px solid #f1f5f9">
                    <h5 class="modal-title fw-bold"><i class="fas fa-paper-plane me-2 text-success"></i>@(isRejectedAT ? "Resubmit Report" : "Forward Report")</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="/Employee/ForwardReport">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reportId" value="@Model.Id" />
                    <div class="modal-body">
                        @* Summary *@
                        <div class="p-3 rounded-3 mb-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Report Total</span>
                                <strong>₹@Model.TotalClaimed.ToString("N2")</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Expenses</span>
                                <strong>@Model.ExpenseClaims.Count item(s)</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Wallet Balance After</span>
                                <strong class="@(walletBal<0?"text-danger":"text-success")">
                                    @(walletBal<0?"-":"")₹@Math.Abs(walletBal).ToString("N2")
                                </strong>
                            </div>
                        </div>
                        @if (walletBal < 0)
                        {
                            <div class="alert alert-warning" style="border-radius:10px;font-size:.85rem">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>₹@Math.Abs(walletBal).ToString("N2") overspent</strong> — will be auto-deducted from your next budget allocation.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info" style="border-radius:10px;font-size:.85rem">
                                <i class="fas fa-info-circle me-2"></i>
                                ₹@walletBal.ToString("N2") unused balance will be returned to your wallet after approval.
                            </div>
                        }
                        <div>
                            <label class="form-label fw-semibold">Notes for Account Team (optional)</label>
                            <textarea name="notes" class="form-control" rows="2" placeholder="Any additional context..." style="border-radius:10px"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top:1px solid #f1f5f9">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius:8px">Cancel</button>
                        <button type="submit" class="btn btn-success fw-semibold" style="border-radius:8px">
                            <i class="fas fa-paper-plane me-2"></i>Forward Report
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* ── DELETE REPORT MODAL (draft only) ── *@
@if (isDraft)
{
    <div class="modal fade" id="deleteReportModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px;border:none">
                <div class="modal-body p-4 text-center">
                    <div style="width:60px;height:60px;background:#fee2e2;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.6rem">🗑️</div>
                    <h5 class="fw-bold">Delete Draft Report?</h5>
                    <p class="text-muted mb-3" style="font-size:.88rem">
                        Deleting <strong>"@Model.ReportTitle"</strong> will remove all <strong>@Model.ExpenseClaims.Count expense(s)</strong>
                        and restore ₹@Model.TotalClaimed.ToString("N2") to your wallet balance.
                    </p>
                    <form method="post" action="/Employee/DeleteReport">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reportId" value="@Model.Id" />
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius:8px">Cancel</button>
                            <button type="submit" class="btn btn-danger fw-semibold" style="border-radius:8px">Yes, Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
