@model ExpenseManagement.ViewModels.EmployeeDashboardVM
@using ExpenseManagement.Models
@{
    ViewData["Title"] = "Dashboard";
    ViewBag.UnreadNotifications = Model.UnreadNotifications;
    var usableBudgets = Model.Budgets.Where(b => !b.IsLocked).ToList();
    bool canCreate = usableBudgets.Any();
    bool isOver = Model.TotalBalance < 0;
}

@* ── TOP WALLET HERO CARD ── *@
<div class="mb-4">
    <div style="background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 100%);border-radius:18px;padding:24px;color:#fff">

        <div style="opacity:.8;font-size:.8rem;letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px">
            <i class="fas fa-wallet me-2"></i>Available Wallet Balance
        </div>

        <div style="font-size:2.6rem;font-weight:800;letter-spacing:-1.5px;line-height:1.1;margin-bottom:4px">
            @if (isOver)
            {
                <span class="text-warning">-₹@Math.Abs(Model.TotalBalance).ToString("N2")</span>
            }
            else
            {
                <text>₹@Model.TotalBalance.ToString("N2")</text>
            }
        </div>
        @if (isOver)
        {
            <div style="font-size:.76rem;opacity:.8;margin-bottom:12px">
                <i class="fas fa-info-circle me-1"></i>
                ₹@Math.Abs(Model.TotalBalance).ToString("N2") will be recovered from next allocation
            </div>
        }

        <div class="row g-2 mt-2">
            <div class="col-4">
                <div style="background:rgba(255,255,255,.13);border-radius:12px;padding:10px 6px;text-align:center">
                    <div style="font-size:1.1rem;font-weight:700">₹@Model.TotalAllocated.ToString("N0")</div>
                    <div style="font-size:.68rem;opacity:.75;margin-top:2px">Total Allocated</div>
                </div>
            </div>
            <div class="col-4">
                <div style="background:rgba(255,255,255,.13);border-radius:12px;padding:10px 6px;text-align:center">
                    <div style="font-size:1.1rem;font-weight:700">₹@Model.TotalSpent.ToString("N0")</div>
                    <div style="font-size:.68rem;opacity:.75;margin-top:2px">Total Spent</div>
                </div>
            </div>
            <div class="col-4">
                <div style="background:rgba(255,255,255,.13);border-radius:12px;padding:10px 6px;text-align:center">
                    <div style="font-size:1.1rem;font-weight:700">@Model.DraftReports.Count</div>
                    <div style="font-size:.68rem;opacity:.75;margin-top:2px">Draft Reports</div>
                </div>
            </div>
        </div>

        @if (usableBudgets.Any())
        {
            var totalAmt   = usableBudgets.Sum(b => b.TotalAmount);
            var totalSpent = usableBudgets.Sum(b => b.SpentAmount);
            var pct        = totalAmt > 0 ? Math.Min(100, (double)(totalSpent / totalAmt * 100)) : 0;
            <div class="mt-3">
                <div class="d-flex justify-content-between mb-1" style="font-size:.75rem;opacity:.8">
                    <span>Budget Used</span><span>@pct.ToString("F0")%</span>
                </div>
                <div style="height:6px;background:rgba(255,255,255,.25);border-radius:99px;overflow:hidden">
                    <div style="height:100%;width:@pct%;background:@(pct>90?"#f87171":pct>70?"#fbbf24":"#4ade80");border-radius:99px;transition:width .4s"></div>
                </div>
            </div>
        }
    </div>
</div>

@* ── IN-PROGRESS REPORTS ── *@
@if (Model.DraftReports.Any())
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="background:#eff6ff;border-bottom:1.5px solid #bfdbfe">
            <span class="fw-semibold"><i class="fas fa-edit me-2 text-primary"></i>In-Progress Reports</span>
            @if (canCreate)
            {
                <a href="/Employee/CreateDraftReport" class="btn btn-sm btn-primary" style="border-radius:8px">
                    <i class="fas fa-plus me-1"></i>New Report
                </a>
            }
        </div>
        <div class="card-body p-0">
            @foreach (var r in Model.DraftReports.OrderByDescending(x => x.CreatedOn))
            {
                <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
                    <div class="flex-fill me-3">
                        <div class="fw-bold">@r.ReportTitle</div>
                        <div class="d-flex gap-3 mt-1 flex-wrap" style="font-size:.8rem">
                            <span class="text-muted"><i class="fas fa-calendar me-1"></i>@r.CreatedOn.ToString("dd MMM yyyy")</span>
                            <span class="text-muted"><i class="fas fa-receipt me-1"></i>@r.ExpenseClaims.Count expense(s)</span>
                        </div>
                        <div class="mt-1 fw-semibold" style="font-size:.82rem;color:#f59e0b">
                            ₹@r.TotalClaimed.ToString("N2") claimed
                        </div>
                    </div>
                    <div class="d-flex gap-1 flex-shrink-0">
                        <a href="/Employee/AddExpense?reportId=@r.Id" class="btn btn-sm btn-primary" style="border-radius:7px"><i class="fas fa-plus"></i></a>
                        <a href="/Employee/ReportDetail/@r.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:7px"><i class="fas fa-eye"></i></a>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ── QUICK ACTIONS ── *@
<div class="card">
    <div class="card-header fw-semibold"><i class="fas fa-bolt me-2"></i>Quick Actions</div>
    <div class="card-body d-flex flex-column gap-2 p-3">
        @if (canCreate)
        {
            <a href="/Employee/CreateDraftReport" class="btn btn-primary w-100" style="border-radius:10px;padding:10px">
                <i class="fas fa-file-plus me-2"></i>Create New Report
            </a>
        }
        else
        {
            <button class="btn btn-secondary w-100" disabled style="border-radius:10px;padding:10px">
                <i class="fas fa-lock me-2"></i>No Active Budget
            </button>
        }
        <a href="/Employee/MyReports" class="btn btn-outline-primary w-100" style="border-radius:10px;padding:10px">
            <i class="fas fa-list me-2"></i>View All Reports
        </a>
        <a href="/Employee/MyBudgets" class="btn btn-outline-secondary w-100" style="border-radius:10px;padding:10px">
            <i class="fas fa-wallet me-2"></i>Budget History
        </a>
    </div>
</div>
