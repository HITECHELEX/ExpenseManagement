@model List<ExpenseManagement.Models.Budget>
@using ExpenseManagement.Models
@{ ViewData["Title"] = "My Wallet"; }

@{
    var activeBudgets = Model.Where(b => b.IsActive && !b.IsLocked).ToList();
    var lockedBudgets = Model.Where(b => b.IsLocked).ToList();
    decimal walletBalance = activeBudgets.Sum(b => b.RemainingBalance);
    bool isOver   = walletBalance < 0;
    decimal totalOwed = isOver ? Math.Abs(walletBalance) : 0;
    var topUpHistory = ViewBag.TopUpHistory as List<WalletTopUp> ?? new List<WalletTopUp>();
}

<h5 class="mb-3 fw-bold"><i class="fas fa-wallet me-2"></i>My Wallet</h5>

@* ── SINGLE WALLET BALANCE CARD ── *@
<div class="mb-4">
    <div style="background:linear-gradient(135deg,@(isOver?"#dc2626,#991b1b":"#1e3a8a,#2563eb"));border-radius:18px;padding:24px 28px;color:#fff">
        <div class="row align-items-center g-3">
            <div class="col-md-5">
                <div style="opacity:.75;font-size:.75rem;text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px">
                    <i class="fas fa-wallet me-2"></i>Current Wallet Balance
                </div>
                <div style="font-size:2.8rem;font-weight:800;letter-spacing:-1.5px;line-height:1">
                    @(isOver ? "-" : "")₹@Math.Abs(walletBalance).ToString("N2")
                </div>
                @if (totalOwed > 0)
                {
                    <div style="background:rgba(0,0,0,.25);border-radius:8px;padding:6px 10px;margin-top:10px;font-size:.78rem">
                        <i class="fas fa-exclamation-triangle me-1 text-warning"></i>
                        ₹@totalOwed.ToString("N2") overspend pending recovery from next top-up
                    </div>
                }
            </div>
            <div class="col-md-7">
                <div class="row g-2 text-center">
                    <div class="col-4">
                        <div style="background:rgba(255,255,255,.13);border-radius:10px;padding:12px 6px">
                            <div style="font-size:1.15rem;font-weight:700">₹@topUpHistory.Sum(t => t.Amount).ToString("N0")</div>
                            <div style="font-size:.68rem;opacity:.75;margin-top:2px">Total Topped Up</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:rgba(255,255,255,.13);border-radius:10px;padding:12px 6px">
                            <div style="font-size:1.15rem;font-weight:700">₹@Model.Sum(b => b.SpentAmount).ToString("N0")</div>
                            <div style="font-size:.68rem;opacity:.75;margin-top:2px">Total Spent</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:rgba(255,255,255,.13);border-radius:10px;padding:12px 6px">
                            <div style="font-size:1.15rem;font-weight:700">@topUpHistory.Count</div>
                            <div style="font-size:.68rem;opacity:.75;margin-top:2px">Total Top-ups</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any() && !topUpHistory.Any())
{
    <div class="card text-center py-5 text-muted">
        <i class="fas fa-wallet fa-3x mb-3 d-block"></i>
        No budget allocated yet. Contact the Account Team to top up your wallet.
    </div>
}
else
{
    @* ── TOP-UP HISTORY ── *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-semibold mb-0"><i class="fas fa-history me-1 text-primary"></i>Top-up History</h6>
        <span class="badge bg-primary rounded-pill">@topUpHistory.Count record(s)</span>
    </div>

    @if (!topUpHistory.Any())
    {
        <div class="card mb-4 text-center py-4 text-muted" style="font-size:.87rem">
            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>No top-ups recorded yet.
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body p-0">
                @foreach (var (t, idx) in topUpHistory.Select((t, i) => (t, topUpHistory.Count - i)))
                {
                    bool neg = t.BalanceAfter < 0;
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge rounded-pill flex-shrink-0" style="background:#eff6ff;color:#2563eb;font-weight:700;font-size:.8rem;padding:6px 10px">#@idx</span>
                            <div>
                                <div class="fw-bold">@t.Purpose</div>
                                <small class="text-muted">
                                    <i class="fas fa-user me-1"></i>@(t.TopUpBy?.FullName ?? "Account Team")
                                    &nbsp;·&nbsp;
                                    <i class="fas fa-clock me-1"></i>@t.TopUpOn.ToString("dd MMM yyyy, hh:mm tt")
                                </small>
                            </div>
                        </div>
                        <div class="d-flex gap-3 text-end">
                            <div>
                                <div style="font-size:.68rem;color:#94a3b8">Amount Added</div>
                                <div class="fw-bold text-primary">+₹@t.Amount.ToString("N2")</div>
                            </div>
                            <div>
                                @{
                                    decimal prevBal = t.BalanceAfter - t.Amount;
                                }
                                <div style="font-size:.68rem;color:#94a3b8">Balance After</div>
                                <div class="fw-bold @(neg ? "text-danger" : "text-success")">
                                    @(neg ? "-" : "")₹@Math.Abs(t.BalanceAfter).ToString("N2")
                                </div>
                                @if (prevBal < 0)
                                {
                                    <div style="font-size:.68rem;color:#f59e0b;margin-top:2px">
                                        <i class="fas fa-exclamation-triangle me-1"></i>₹@Math.Abs(prevBal).ToString("N2") debt recovered
                                    </div>
                                }
                                else if (prevBal > 0)
                                {
                                    <div style="font-size:.68rem;color:#64748b;margin-top:2px">
                                        <i class="fas fa-layer-group me-1"></i>Incl. ₹@prevBal.ToString("N2") carry-forward
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── LOCKED / CLOSED WALLETS (if any from old system) ── *@
    @if (lockedBudgets.Any())
    {
        <h6 class="fw-semibold mb-2 mt-1 text-muted"><i class="fas fa-lock me-1"></i>Closed Wallets <small class="fw-normal">(archived)</small></h6>
        <div class="card">
            <div class="card-body p-0">
                @foreach (var b in lockedBudgets.OrderByDescending(x => x.AllocatedOn))
                {
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom flex-wrap gap-2 opacity-65">
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:36px;height:36px;background:#f1f5f9;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="fas fa-lock text-muted"></i>
                            </div>
                            <div>
                                <div class="fw-semibold text-muted">@b.Purpose <span class="badge bg-secondary ms-1" style="font-size:.6rem">Closed</span></div>
                                <small class="text-muted">@b.AllocatedOn.ToString("dd MMM yyyy")</small>
                            </div>
                        </div>
                        <div class="d-flex gap-3 text-end">
                            <div>
                                <div style="font-size:.68rem;color:#94a3b8">Allocated</div>
                                <div class="fw-semibold text-muted">₹@b.TotalAmount.ToString("N0")</div>
                            </div>
                            <div>
                                <div style="font-size:.68rem;color:#94a3b8">Spent</div>
                                <div class="fw-semibold text-muted">₹@b.SpentAmount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}


