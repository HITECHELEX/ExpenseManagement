@model List<ExpenseManagement.Models.ExpenseReport>
@using ExpenseManagement.Models
@{ ViewData["Title"] = "Expense Reports"; var currentStatus = ViewBag.CurrentStatus as string; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="fas fa-file-invoice me-2"></i>Expense Reports</h5>
</div>

<div class="mb-3 d-flex flex-wrap gap-2">
    <a href="/AccountTeam/Reports?status=SubmittedToAccountTeam" class="btn btn-sm @(currentStatus == "SubmittedToAccountTeam" ? "btn-primary" : "btn-outline-secondary")">Pending</a>
    <a href="/AccountTeam/Reports?status=ForwardedToManagement" class="btn btn-sm @(currentStatus == "ForwardedToManagement" ? "btn-primary" : "btn-outline-secondary")">Forwarded</a>
    <a href="/AccountTeam/Reports?status=ApprovedByManagement" class="btn btn-sm @(currentStatus == "ApprovedByManagement" ? "btn-success" : "btn-outline-secondary")">Approved</a>
    <a href="/AccountTeam/Reports?status=RejectedByAccountTeam" class="btn btn-sm @(currentStatus == "RejectedByAccountTeam" ? "btn-danger" : "btn-outline-secondary")">Rejected by AT</a>
    <a href="/AccountTeam/Reports?status=RejectedByManagement" class="btn btn-sm @(currentStatus == "RejectedByManagement" ? "btn-danger" : "btn-outline-secondary")">Rejected by Mgmt</a>
</div>

@if (!Model.Any())
{ <div class="card text-center py-5 text-muted"><i class="fas fa-inbox fa-3x mb-3 d-block"></i>No reports found</div> }

@foreach (var r in Model)
{
    var (cls, txt) = r.Status switch {
        ReportStatus.SubmittedToAccountTeam => ("badge-submitted","Awaiting Review"),
        ReportStatus.ForwardedToManagement => ("badge-forwarded","At Management"),
        ReportStatus.ApprovedByManagement => ("badge-approved","Approved"),
        ReportStatus.RejectedByManagement => ("badge-rejected","Rejected"),
        _ => ("badge-secondary", r.Status.ToString())
    };
    <div class="card mb-2">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <div class="fw-semibold">@r.ReportTitle</div>
                <small class="text-muted">@r.Employee?.FullName · @r.CreatedOn.ToString("dd MMM yyyy") · ₹@r.TotalClaimed.ToString("N2")</small>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <span class="badge @cls">@txt</span>
                <a href="/AccountTeam/ReportDetail/@r.Id" class="btn btn-sm btn-outline-primary">View</a>
                @if (r.Status == ReportStatus.ApprovedByManagement)
                {
                    <a href="/AccountTeam/DownloadReport/@r.Id" class="btn btn-sm btn-success"><i class="fas fa-download"></i></a>
                }
            </div>
        </div>
    </div>
}
