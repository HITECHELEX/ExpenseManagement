@model List<ExpenseManagement.Models.User>
@{ ViewData["Title"] = "Employees"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="fas fa-users me-2"></i>Employees</h5>
    <a href="/AccountTeam/CreateEmployee" class="btn btn-primary btn-sm"><i class="fas fa-user-plus me-1"></i>Add Employee</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    @foreach (var emp in Model)
    {
        var activeBudgets = emp.Budgets.Where(b => b.IsActive).ToList();
        var totalBalance = activeBudgets.Sum(b => b.RemainingBalance);
        <div class="col-md-6 col-lg-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:#eff6ff;color:#2563eb;font-weight:700;font-size:1.1rem;flex-shrink:0">
                            @emp.FullName[0]
                        </div>
                        <div>
                            <div class="fw-semibold">@emp.FullName</div>
                            <small class="text-muted">@emp.Email</small>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between text-center mb-3">
                        <div><div class="fw-bold">@activeBudgets.Count</div><small class="text-muted">Active Budgets</small></div>
                        <div><div class="fw-bold text-success">₹@totalBalance.ToString("N0")</div><small class="text-muted">Balance</small></div>
                        <div><div class="fw-bold text-muted">@emp.Department</div><small class="text-muted">Dept</small></div>
                    </div>
                    <a href="/AccountTeam/AllocateBudget" class="btn btn-outline-primary btn-sm w-100 mb-2">
                        <i class="fas fa-plus-circle me-1"></i>Top Up Wallet
                    </a>
                    <div class="d-flex gap-2">
                        <a href="/AccountTeam/EditEmployee/@emp.Id" class="btn btn-outline-secondary btn-sm flex-fill">
                            <i class="fas fa-edit me-1"></i>Edit
                        </a>
                        <form method="post" action="/AccountTeam/DeleteEmployee/@emp.Id"
                              onsubmit="return confirm('Delete @emp.FullName? This cannot be undone.');" style="flex:1">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

