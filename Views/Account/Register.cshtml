@model ExpenseManagement.ViewModels.RegisterVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - ExpenseTrack</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); min-height: 100vh; display: flex; align-items: center; }
        .reg-card { background: #fff; border-radius: 16px; padding: 36px; width: 100%; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
        .form-control, .form-select { border-radius: 8px; border-color: #e2e8f0; padding: 10px 14px; }
        .form-control:focus, .form-select:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
        .btn-primary { background: #2563eb; border: none; border-radius: 8px; padding: 11px; font-weight: 600; }
    </style>
</head>
<body>
<div class="container d-flex justify-content-center py-5">
    <div class="reg-card">
        <h5 class="fw-700 mb-1" style="color:#1e293b; font-weight:700;"><i class="fas fa-chart-pie me-2" style="color:#2563eb;"></i>ExpenseTrack</h5>
        <p class="text-muted mb-4" style="font-size:.85rem;">Create a new account</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="alert alert-danger py-2" style="font-size:.85rem;display:@(ViewData.ModelState.IsValid?"none":"block")"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold text-secondary" style="font-size:.82rem;">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold text-secondary" style="font-size:.82rem;">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="john@company.com" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold text-secondary" style="font-size:.82rem;">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-secondary" style="font-size:.82rem;">Role</label>
                    <select asp-for="Role" class="form-select">
                        <option value="0">Employee</option>
                        <option value="1">Account Team</option>
                        <option value="2">Management</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-secondary" style="font-size:.82rem;">Department</label>
                    <input asp-for="Department" class="form-control" placeholder="e.g. Sales" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-4">
                <i class="fas fa-user-plus me-2"></i>Create Account
            </button>
            <div class="text-center mt-3">
                <a href="/Account/Login" style="font-size:.85rem; color:#2563eb; text-decoration:none;">
                    <i class="fas fa-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </form>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
